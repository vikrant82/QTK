{
  "name": "qtk-workspace",
  "private": true,
  "type": "module",
  "description": "Token compression layer for AI coding agents — opencode plugin (and forks)",
  "license": "MIT",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "build": "cd packages/qtk-plugin && bun run build",
    "rebuild:all": "bash scripts/rebuild-all.sh",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit",
    "bench": "bun run scripts/benchmark.ts",
    "bench:sidecar": "bun run scripts/benchmark-sidecar.ts",
    "install-into-opencode": "bun run scripts/install-into-opencode.ts",
    "import-rtk-filters": "bun run scripts/import-rtk-filters.ts"
  }
}
