{
  "name": "@qtk/plugin",
  "version": "0.3.0",
  "description": "opencode plugin: deterministic, in-process token compression for tool outputs. Downstream of RTK (rtk-ai/rtk).",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./src": "./src/index.ts",
    "./compressors/*": "./src/compressors/*.ts",
    "./tools/*": "./src/tools/*.ts"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit",
    "prepublishOnly": "bun run build && bun test"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.1.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.1.21",
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "opencode",
    "ai-agents",
    "token-compression",
    "context-window",
    "developer-tools",
    "llm",
    "claude-code",
    "plugin",
    "rtk-derivative"
  ],
  "homepage": "https://github.com/qalarc/QTK",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qalarc/QTK.git",
    "directory": "packages/qtk-plugin"
  },
  "bugs": {
    "url": "https://github.com/qalarc/QTK/issues"
  },
  "author": "fivelidz <https://qalarc.com>",
  "license": "MIT"
}
